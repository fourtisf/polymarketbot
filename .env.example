# ─── Polymarket credentials ───
POLYGON_PRIVATE_KEY=0x_your_private_key_here
POLYGON_PUBLIC_KEY=0x_your_public_address_here
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_PASSPHRASE=

# ─── Telegram ───
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Dashboard ───
DASHBOARD_PORT=8081
DASHBOARD_TOKEN=change_me_to_something_secret
STARTING_BALANCE=200

# ─── Trading parameters ───
BASE_TRADE_SIZE=5
MAX_TRADE_SIZE=25
MAX_SESSION_LOSS=20
MAX_DAILY_LOSS=30
MAX_DAILY_TRADES=50
MAX_CONSECUTIVE_LOSSES=4
MIN_CONFIDENCE=60
MIN_DELTA_PCT=0.05
ENTRY_WINDOW_START=60
ENTRY_WINDOW_END=5
ABSOLUTE_MAX_ENTRY_PRICE=0.62

# ─── TP / SL early-exit (sells before window close) ───
# TP_PRICE: sell when token best_bid >= this (lock profit)
# SL_PRICE: sell when token best_bid <= this (cut loss)
# Set TP_SL_ENABLED=false to disable both.
TP_SL_ENABLED=true
TP_PRICE=0.85
SL_PRICE=0.20

# ─── Dry-run helpers ───
# When WS feeds are quiet in --dry-run mode, fall back to synthetic
# prices so the operator can see the full entry / TP / SL flow.
DRY_RUN_SYNTH_PRICES=true
